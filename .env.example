# The web app and John load this root file for local development.
DATA_SOURCE=local
PORT=8080

# Shared Google Cloud settings
GOOGLE_CLOUD_PROJECT=sprinternship-bld-2026
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# BigQuery mode
BQ_PROJECT_ID=sprinternship-bld-2026
BQ_DATASET=msa_manager
BQ_CUSTOMERS_TABLE=customer_profiles
BQ_MSA_UPDATES_TABLE=msa_updates

# Cloud Asset customer-profile export
GCP_SCOPE=
CUSTOMER_CLIENT_ID=
CUSTOMER_ACCOUNT_NAME=
CUSTOMER_DATA_BUCKET=
CUSTOMER_RAW_PREFIX=raw_client_data
CUSTOMER_PROCESSED_PREFIX=processed_client_data

# John conversational-agent prototype
JOHN_MODEL=gemini-3.5-flash
JOHN_PRINCIPAL=usagi@example.com
JOHN_USER_ID=088
JOHN_ENABLED=true
JOHN_RATE_LIMIT_PER_CLIENT=25
JOHN_RATE_LIMIT_CLIENT_WINDOW_SECONDS=300
JOHN_RATE_LIMIT_GLOBAL=300
JOHN_RATE_LIMIT_GLOBAL_WINDOW_SECONDS=3600

# Optional email settings used by scripts/combine_and_send.py
EMAIL_SENDER=msa-manager@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
